# Copy this file to .env at the project root and fill in your values

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amplimentor
DB_USER=postgres
DB_PASS=your_postgres_password_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Session Configuration
SESSION_SECRET=your_strong_random_session_secret_here

# Server Configuration
PORT=3000
NODE_ENV=development
