  "description": "Amplimentor - Student Mentoring Platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon --quiet backend/server.js",
    "frontend": "node frontend/server.js",
    "migrate": "npx sequelize-cli --options-path backend/.sequelizerc db:migrate",
